#pragma once

// ============================================================================
// SimpleCommKit Version — auto-generated by CMake from VERSION file
// ============================================================================

#define SIMPLECOMMKIT_VERSION       "@SIMPLECOMMKIT_VERSION@"
#define SIMPLECOMMKIT_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define SIMPLECOMMKIT_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define SIMPLECOMMKIT_VERSION_PATCH @PROJECT_VERSION_PATCH@

#include <cstdint>
#include <string>

namespace SimpleCommKit {

// ---- 版本信息结构体 ----
struct SimpleCommKitVersion {
    uint32_t major = SIMPLECOMMKIT_VERSION_MAJOR;
    uint32_t minor = SIMPLECOMMKIT_VERSION_MINOR;
    uint32_t patch = SIMPLECOMMKIT_VERSION_PATCH;

    std::string to_string() const {
        return std::to_string(major) + "." +
               std::to_string(minor) + "." +
               std::to_string(patch);
    }
};

// ---- 便捷函数 ----
/// 获取完整版本号字符串，如 "0.1.0"
inline const char* getSimpleCommKitVersion() {
    return SIMPLECOMMKIT_VERSION;
}

/// 获取版本结构体
inline SimpleCommKitVersion getSimpleCommKitVersionInfo() {
    return {};
}

} // namespace SimpleCommKit
