#pragma once

// ============================================================================
// SimpleCommKit Version — auto-generated by CMake from VERSION file
//
// 版本号不暴露为宏，所有版本信息通过库导出函数获取，支持 so/dll 替换后自动更新。
// ============================================================================

#include <cstdint>
#include <string>

#include <SimpleCommKitExport.h>

namespace SimpleCommKit {

// ---- 版本信息结构体 ----
struct SimpleCommKitVersion {
    uint32_t major = 0;
    uint32_t minor = 0;
    uint32_t patch = 0;

    std::string to_string() const {
        return std::to_string(major) + "." +
               std::to_string(minor) + "." +
               std::to_string(patch);
    }
};

// ---- 版本函数（实现于 .cpp，随 so/dll 一起更新）----
/// 获取完整版本号字符串，如 "0.1.0"
SIMPLECOMMKIT_API const char* getSimpleCommKitVersion();

/// 获取版本结构体
SIMPLECOMMKIT_API SimpleCommKitVersion getSimpleCommKitVersionInfo();

} // namespace SimpleCommKit
